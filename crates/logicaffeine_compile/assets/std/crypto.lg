## Note
NTT-domain polynomial product for ML-DSA.

## To mldsaNttMul (a: Seq of Word32) and (b: Seq of Word32) -> Seq of Word32:
    Let ah be mldsaNtt(a).
    Let bh be mldsaNtt(b).
    Let ch be pointwiseMontgomery(ah, bh).
    Return mldsaFreezePoly(mldsaInvNttToMont(ch)).

## ML-DSA verify glue — FIPS-204 §7.4 rounding (HighBits / UseHint), pure i32 arithmetic.

## Note
Freezes one integer coefficient into canonical range mod q.

## To mldsaFreezeI (r: Int) -> Int:
    Return ((r % 8380417) + 8380417) % 8380417.

## Note
The high-bits decomposition of a coefficient (FIPS 204 HighBits).

## To mldsaHighBits (r: Int) -> Int:
    Let rr be mldsaFreezeI(r).
    Let a1 be (rr + 127) / 128.
    Set a1 to (a1 * 1025 + 2097152) / 4194304.
    Return a1 % 16.

## Note
Applies a hint bit to recover the true high bits (FIPS 204 UseHint).

## To mldsaUseHint (h: Int) and (r: Int) -> Int:
    Let rr be mldsaFreezeI(r).
    Let a1 be (rr + 127) / 128.
    Set a1 to (a1 * 1025 + 2097152) / 4194304.
    Set a1 to a1 % 16.
    Let a0 be rr - a1 * 523776.
    If a0 is greater than 4190208:
        Set a0 to a0 - 8380417.
    If h is equal to 0:
        Return a1.
    If a0 is greater than 0:
        Return (a1 + 1) % 16.
    Return (a1 - 1 + 16) % 16.

## ML-DSA verify glue — FIPS-204 w1Encode (4-bit SimpleBitPack).

## Note
Packs the w1 high-bits vector into bytes for hashing.

## To mldsaW1Encode (w1: Seq of Int) -> Seq of Int:
    Let mutable out be a new Seq of Int.
    Let n be (length of w1) / 2.
    Repeat for j from 0 to n - 1:
        Let lo be item (2 * j + 1) of w1.
        Let hi be item (2 * j + 2) of w1.
        Push (lo + hi * 16) to out.
    Return out.

## ML-DSA verify glue — t1 decode (SimpleBitUnpack 10) + SampleInBall placement (FIPS-204 §7.3).

## Note
Unpacks the 10-bit t1 coefficients of a public key.

## To mldsaUnpackT1 (b: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 63:
        Let a0 be item (5 * i + 1) of b.
        Let a1 be item (5 * i + 2) of b.
        Let a2 be item (5 * i + 3) of b.
        Let a3 be item (5 * i + 4) of b.
        Let a4 be item (5 * i + 5) of b.
        Push ((a0 + a1 * 256) % 1024) to r.
        Push ((a1 / 4 + a2 * 64) % 1024) to r.
        Push ((a2 / 16 + a3 * 16) % 1024) to r.
        Push ((a3 / 64 + a4 * 4) % 1024) to r.
    Return r.

## Note
SampleInBall from a prepared SHAKE256 buffer: tau signed flips.

## To mldsaSampleInBallBuf (buf: Seq of Int) -> Seq of Int:
    Let mutable c be a new Seq of Int.
    Repeat for k from 1 to 256:
        Push 0 to c.
    Let mutable signBits be 0.
    Let mutable mult be 1.
    Repeat for k from 1 to 7:
        Set signBits to signBits + (item k of buf) * mult.
        Set mult to mult * 256.
    Let mutable pos be 9.
    Repeat for i from 207 to 255:
        Let mutable j be 0.
        Let mutable found be 0.
        While found is equal to 0:
            Let candidate be item pos of buf.
            Set pos to pos + 1.
            If candidate is at most i:
                Set j to candidate.
                Set found to 1.
        Set item (i + 1) of c to (item (j + 1) of c).
        Let bit be signBits % 2.
        Set signBits to signBits / 2.
        Set item (j + 1) of c to (1 - 2 * bit).
    Return c.

## ML-DSA verify glue — z decode (BitUnpack γ1) + ExpandA element (RejNTTPoly placement).

## Note
Unpacks the 20-bit signed z coefficients of a signature.

## To mldsaUnpackZ (b: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 127:
        Let a0 be item (5 * i + 1) of b.
        Let a1 be item (5 * i + 2) of b.
        Let a2 be item (5 * i + 3) of b.
        Let a3 be item (5 * i + 4) of b.
        Let a4 be item (5 * i + 5) of b.
        Let z0 be a0 + a1 * 256 + (a2 % 16) * 65536.
        Let z1 be a2 / 16 + a3 * 16 + a4 * 4096.
        Push (524288 - z0) to r.
        Push (524288 - z1) to r.
    Return r.

## Note
Rejection-samples an NTT polynomial from a prepared buffer.

## To mldsaRejNttPolyBuf (buf: Seq of Int) -> Seq of Int:
    Let mutable a be a new Seq of Int.
    Let mutable pos be 0.
    Let mutable ctr be 0.
    While ctr is less than 256:
        Let b0 be item (pos + 1) of buf.
        Let b1 be item (pos + 2) of buf.
        Let b2 be item (pos + 3) of buf.
        Let d be b0 + b1 * 256 + (b2 % 128) * 65536.
        Set pos to pos + 3.
        If d is less than 8380417:
            Push d to a.
            Set ctr to ctr + 1.
    Return a.

## ML-DSA verify glue — hint decode (sparse indices → {0,1} polys) + poly subtract (i32 lanes).

## Note
Unpacks the hint bit positions of a signature.

## To mldsaUnpackHint (b: Seq of Int) -> Seq of Int:
    Let mutable h be a new Seq of Int.
    Repeat for x from 1 to 1536:
        Push 0 to h.
    Let mutable k be 0.
    Repeat for i from 0 to 5:
        Let cnt be item (55 + i + 1) of b.
        Let mutable j be k.
        While j is less than cnt:
            Let idx be item (j + 1) of b.
            Set item (i * 256 + idx + 1) of h to 1.
            Set j to j + 1.
        Set k to cnt.
    Return h.

## Note
Coefficient-wise subtraction of two polynomials.

## To mldsaPolySub (a: Seq of Word32) and (b: Seq of Word32) -> Seq of Word32:
    Let mutable out be a new Seq of Word32.
    Repeat for v from 0 to 31:
        Let av be lanes8Word32(sub8(a, 8 * v)).
        Let bv be lanes8Word32(sub8(b, 8 * v)).
        Repeat for x in seqOfLanes8(av - bv):
            Push x to out.
    Return out.

## ML-DSA verify glue — SHAKE wrappers (native SHAKE → the proven placement/rejection logic).

## Note
SampleInBall from the challenge seed (FIPS 204).

## To mldsaSampleInBall (cTilde: Seq of Int) -> Seq of Int:
    Return mldsaSampleInBallBuf(shake256(cTilde, 512)).

## Note
Expands one matrix entry of A from the public seed.

## To mldsaExpandAElem (seed: Seq of Int) -> Seq of Int:
    Return mldsaRejNttPolyBuf(shake128(seed, 1024)).

## ML-DSA verify — the full Logos verify assembly (FIPS-204 Algorithm 3 core: c̃ equality).

## Note
Copies a length-len slice of a byte sequence.

## To mldsaSubRange (s: Seq of Int) and (off: Int) and (len: Int) -> Seq of Int:
    Let r be a new Seq of Int.
    Repeat for i from 1 to len:
        Push (item (off + i) of s) to r.
    Return r.

## Note
Copies a length-len Word32 slice.

## To mldsaSubRangeW (s: Seq of Word32) and (off: Int) and (len: Int) -> Seq of Word32:
    Let r be a new Seq of Word32.
    Repeat for i from 1 to len:
        Push (item (off + i) of s) to r.
    Return r.

## Note
Reads a Word32 as a signed centered integer.

## To mldsaToS32 (w: Word32) -> Int:
    Let v be intOfWord32(w).
    If v is at least 2147483648:
        Return v - 4294967296.
    Return v.

## Note
Widens a sequence of Ints into Word32 coefficients.

## To mldsaIntsToW32 (p: Seq of Int) -> Seq of Word32:
    Let mutable out be a new Seq of Word32.
    Repeat for x in p:
        Push word32(x) to out.
    Return out.

## Note
Scales unpacked t1 by 2^13 for verification.

## To mldsaScaleT1 (p: Seq of Int) -> Seq of Word32:
    Let mutable out be a new Seq of Word32.
    Repeat for x in p:
        Push word32(x * 8192) to out.
    Return out.

## Note
Coefficient-wise addition of two polynomials.

## To mldsaPolyAdd (a: Seq of Word32) and (b: Seq of Word32) -> Seq of Word32:
    Let mutable out be a new Seq of Word32.
    Repeat for v from 0 to 31:
        Let av be lanes8Word32(sub8(a, 8 * v)).
        Let bv be lanes8Word32(sub8(b, 8 * v)).
        Repeat for x in seqOfLanes8(av + bv):
            Push x to out.
    Return out.

## Note
Checks that a packed hint encoding is canonical (FIPS 204).

## To mldsaHintValid (b: Seq of Int) and (base: Int) -> Int:
    Let mutable k be 0.
    Let mutable ok be 1.
    Repeat for i from 0 to 5:
        Let cnt be item (base + 55 + i + 1) of b.
        If cnt is less than k:
            Set ok to 0.
        If cnt is greater than 55:
            Set ok to 0.
        Let mutable jmax be cnt.
        If jmax is greater than 55:
            Set jmax to 55.
        Let mutable j be k.
        While j is less than jmax:
            If j is greater than k:
                If (item (base + j + 1) of b) is at most (item (base + j) of b):
                    Set ok to 0.
            Set j to j + 1.
        Set k to cnt.
    Let mutable pp be k.
    If pp is greater than 55:
        Set pp to 55.
    While pp is less than 55:
        If (item (base + pp + 1) of b) is greater than 0:
            Set ok to 0.
        Set pp to pp + 1.
    Return ok.

## Note
ML-DSA-65 verification written in LOGOS; 1 for valid, else 0.

## To mldsaVerifyLogos (pk: Seq of Int) and (msg: Seq of Int) and (sig: Seq of Int) -> Int:
    Let rho be mldsaSubRange(pk, 0, 32).
    Let mutable hk be 0.
    Let mutable hintOk be 1.
    Repeat for i from 0 to 5:
        Let cnt be item (3304 + i) of sig.
        If cnt is less than hk:
            Set hintOk to 0.
        If cnt is greater than 55:
            Set hintOk to 0.
        Let mutable jmax be cnt.
        If jmax is greater than 55:
            Set jmax to 55.
        Let mutable hj be hk.
        While hj is less than jmax:
            If hj is greater than hk:
                If (item (3249 + hj) of sig) is at most (item (3248 + hj) of sig):
                    Set hintOk to 0.
            Set hj to hj + 1.
        Set hk to cnt.
    Let mutable pp be hk.
    If pp is greater than 55:
        Set pp to 55.
    While pp is less than 55:
        If (item (3249 + pp) of sig) is greater than 0:
            Set hintOk to 0.
        Set pp to pp + 1.
    If hintOk is equal to 0:
        Return 0.
    Let mutable zbOk be 1.
    Repeat for zr from 0 to 4:
        Let zbase be 48 + 640 * zr.
        Repeat for zi from 0 to 127:
            Let zo be zbase + 5 * zi.
            Let zb0 be item (zo + 1) of sig.
            Let zb1 be item (zo + 2) of sig.
            Let zb2 be item (zo + 3) of sig.
            Let zb3 be item (zo + 4) of sig.
            Let zb4 be item (zo + 5) of sig.
            Let zz0 be zb0 + zb1 * 256 + (zb2 % 16) * 65536.
            Let zz1 be (zb2 / 16) + zb3 * 16 + zb4 * 4096.
            Let mutable za0 be 524288 - zz0.
            If za0 is less than 0:
                Set za0 to 0 - za0.
            If za0 is at least 524092:
                Set zbOk to 0.
            Let mutable za1 be 524288 - zz1.
            If za1 is less than 0:
                Set za1 to 0 - za1.
            If za1 is at least 524092:
                Set zbOk to 0.
    If zbOk is equal to 0:
        Return 0.
    Let tr be shake256(pk, 64).
    Let mutable muIn be a new Seq of Int.
    Repeat for x in tr:
        Push x to muIn.
    Push 0 to muIn.
    Push 0 to muIn.
    Repeat for x in msg:
        Push x to muIn.
    Let mu be shake256(muIn, 64).
    Let cTilde be mldsaSubRange(sig, 0, 48).
    Let cHat be mldsaNtt(mldsaIntsToW32(mldsaSampleInBall(cTilde))).
    Let mutable zHatFlat be a new Seq of Word32.
    Repeat for j from 0 to 4:
        Let zj be mldsaUnpackZ(mldsaSubRange(sig, 48 + 640 * j, 640)).
        Repeat for x in mldsaNtt(mldsaIntsToW32(zj)):
            Push x to zHatFlat.
    Let hAll be mldsaUnpackHint(mldsaSubRange(sig, 3248, 61)).
    Let mutable ctIn be a new Seq of Int.
    Repeat for x in mu:
        Push x to ctIn.
    Repeat for i from 0 to 5:
        Let mutable acc be a new Seq of Word32.
        Repeat for k from 1 to 256:
            Push word32(0) to acc.
        Repeat for j from 0 to 4:
            Let mutable seed be a new Seq of Int.
            Repeat for x in rho:
                Push x to seed.
            Push j to seed.
            Push i to seed.
            Let aHatIJ be mldsaExpandAElem(seed).
            Set acc to mldsaPolyAdd(acc, pointwiseMontgomery(mldsaIntsToW32(aHatIJ), mldsaSubRangeW(zHatFlat, 256 * j, 256))).
        Let t1i be mldsaUnpackT1(mldsaSubRange(pk, 32 + 320 * i, 320)).
        Let t1dHat be mldsaNtt(mldsaScaleT1(t1i)).
        Set acc to mldsaPolySub(acc, pointwiseMontgomery(cHat, t1dHat)).
        Let wp be mldsaInvNttToMont(acc).
        Let mutable w1 be a new Seq of Int.
        Repeat for c from 0 to 255:
            Let hc be item (i * 256 + c + 1) of hAll.
            Let wc be mldsaToS32(item (c + 1) of wp).
            Push mldsaUseHint(hc, wc) to w1.
        Repeat for x in mldsaW1Encode(w1):
            Push x to ctIn.
    Let cTildeP be shake256(ctIn, 48).
    Let mutable eq be 1.
    Repeat for k from 1 to 48:
        Let diff be (item k of cTilde) - (item k of cTildeP).
        If diff is greater than 0:
            Set eq to 0.
        If diff is less than 0:
            Set eq to 0.
    Return eq.

## ML-DSA keygen blocks — ExpandS (RejBounded η=4) + Power2Round→t1 + pack_t1.

## Note
Rejection-samples eta-bounded coefficients from a buffer.

## To mldsaRejBoundedBuf (buf: Seq of Int) -> Seq of Int:
    Let mutable a be a new Seq of Int.
    Let mutable pos be 0.
    Let mutable ctr be 0.
    While ctr is less than 256:
        Let b be item (pos + 1) of buf.
        Set pos to pos + 1.
        Let lo be b % 16.
        Let hi be b / 16.
        If lo is less than 9:
            Push (4 - lo) to a.
            Set ctr to ctr + 1.
        If hi is less than 9:
            If ctr is less than 256:
                Push (4 - hi) to a.
                Set ctr to ctr + 1.
    Return a.

## Note
Expands one secret vector polynomial from the seed.

## To mldsaExpandSElem (seed: Seq of Int) -> Seq of Int:
    Return mldsaRejBoundedBuf(shake256(seed, 512)).

## Note
The high half of Power2Round: t1 from t (FIPS 204).

## To mldsaPower2RoundT1 (t: Int) -> Int:
    Let r be ((t % 8380417) + 8380417) % 8380417.
    Return (r + 4095) / 8192.

## Note
Packs 10-bit t1 coefficients into public-key bytes.

## To mldsaPackT1 (t1: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 63:
        Let a0 be item (4 * i + 1) of t1.
        Let a1 be item (4 * i + 2) of t1.
        Let a2 be item (4 * i + 3) of t1.
        Let a3 be item (4 * i + 4) of t1.
        Push (a0 % 256) to r.
        Push ((a0 / 256 + a1 * 4) % 256) to r.
        Push ((a1 / 64 + a2 * 16) % 256) to r.
        Push ((a2 / 16 + a3 * 64) % 256) to r.
        Push (a3 / 4) to r.
    Return r.

## ML-DSA sign glue — sk decode (η/t0), pack (z/hint), low-bits + make-hint (FIPS-204 Algorithm 2).

## Note
Unpacks eta-range secret coefficients.

## To mldsaUnpackEta (b: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 255:
        Let byte be item (i / 2 + 1) of b.
        Let mutable nib be byte % 16.
        If (i % 2) is equal to 1:
            Set nib to byte / 16.
        Push (4 - nib) to r.
    Return r.

## Note
Unpacks the 13-bit t0 coefficients of a secret key.

## To mldsaUnpackT0 (b: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 31:
        Let c0 be item (13 * i + 1) of b.
        Let c1 be item (13 * i + 2) of b.
        Let c2 be item (13 * i + 3) of b.
        Let c3 be item (13 * i + 4) of b.
        Let c4 be item (13 * i + 5) of b.
        Let c5 be item (13 * i + 6) of b.
        Let c6 be item (13 * i + 7) of b.
        Let c7 be item (13 * i + 8) of b.
        Let c8 be item (13 * i + 9) of b.
        Let c9 be item (13 * i + 10) of b.
        Let c10 be item (13 * i + 11) of b.
        Let c11 be item (13 * i + 12) of b.
        Let c12 be item (13 * i + 13) of b.
        Push (4096 - ((c0 + c1 * 256) % 8192)) to r.
        Push (4096 - ((c1 / 32 + c2 * 8 + c3 * 2048) % 8192)) to r.
        Push (4096 - ((c3 / 4 + c4 * 64) % 8192)) to r.
        Push (4096 - ((c4 / 128 + c5 * 2 + c6 * 512) % 8192)) to r.
        Push (4096 - ((c6 / 16 + c7 * 16 + c8 * 4096) % 8192)) to r.
        Push (4096 - ((c8 / 2 + c9 * 128) % 8192)) to r.
        Push (4096 - ((c9 / 64 + c10 * 4 + c11 * 1024) % 8192)) to r.
        Push (4096 - ((c11 / 8 + c12 * 32) % 8192)) to r.
    Return r.

## Note
The low-bits decomposition of a coefficient (FIPS 204 LowBits).

## To mldsaLowBits (r: Int) -> Int:
    Let rr be mldsaFreezeI(r).
    Let mutable a1 be (rr + 127) / 128.
    Set a1 to (a1 * 1025 + 2097152) / 4194304.
    Set a1 to a1 % 16.
    Let mutable a0 be rr - a1 * 523776.
    If a0 is greater than 4190208:
        Set a0 to a0 - 8380417.
    Return a0.

## Note
Computes the hint bit for one coefficient (FIPS 204 MakeHint).

## To mldsaMakeHint (z: Int) and (r: Int) -> Int:
    If mldsaHighBits(r) is equal to mldsaHighBits(r + z):
        Return 0.
    Return 1.

## Note
Packs signed z coefficients into signature bytes.

## To mldsaPackZ (p: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 127:
        Let t0 be 524288 - (item (2 * i + 1) of p).
        Let t1 be 524288 - (item (2 * i + 2) of p).
        Push (t0 % 256) to r.
        Push ((t0 / 256) % 256) to r.
        Push ((t0 / 65536) + (t1 % 16) * 16) to r.
        Push ((t1 / 16) % 256) to r.
        Push ((t1 / 4096) % 256) to r.
    Return r.

## Note
Packs hint positions into the signature's hint encoding.

## To mldsaPackHint (h: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for x from 1 to 61:
        Push 0 to r.
    Let mutable k be 0.
    Repeat for i from 0 to 5:
        Repeat for j from 0 to 255:
            If (item (i * 256 + j + 1) of h) is greater than 0:
                Set item (k + 1) of r to j.
                Set k to k + 1.
        Set item (55 + i + 1) of r to k.
    Return r.

## ML-DSA sign — the full Logos deterministic signature (FIPS-204 Algorithm 2, rnd=0).

## Note
Centers a value into the symmetric range around zero.

## To mldsaCenterI (x: Int) -> Int:
    Let r be mldsaFreezeI(x).
    If r is greater than 4190208:
        Return r - 8380417.
    Return r.

## Note
ML-DSA-65 signing written in LOGOS: the full rejection loop.

## To mldsaSignLogos (sk: Seq of Int) and (msg: Seq of Int) -> Seq of Int:
    Let rho be mldsaSubRange(sk, 0, 32).
    Let kk be mldsaSubRange(sk, 32, 32).
    Let tr be mldsaSubRange(sk, 64, 64).
    Let mutable s1HatFlat be a new Seq of Word32.
    Repeat for j from 0 to 4:
        Repeat for x in mldsaNtt(mldsaIntsToW32(mldsaUnpackEta(mldsaSubRange(sk, 128 + 128 * j, 128)))):
            Push x to s1HatFlat.
    Let mutable s2HatFlat be a new Seq of Word32.
    Repeat for i from 0 to 5:
        Repeat for x in mldsaNtt(mldsaIntsToW32(mldsaUnpackEta(mldsaSubRange(sk, 768 + 128 * i, 128)))):
            Push x to s2HatFlat.
    Let mutable t0HatFlat be a new Seq of Word32.
    Repeat for i from 0 to 5:
        Repeat for x in mldsaNtt(mldsaIntsToW32(mldsaUnpackT0(mldsaSubRange(sk, 1536 + 416 * i, 416)))):
            Push x to t0HatFlat.
    Let mutable muIn be a new Seq of Int.
    Repeat for x in tr:
        Push x to muIn.
    Push 0 to muIn.
    Push 0 to muIn.
    Repeat for x in msg:
        Push x to muIn.
    Let mu be shake256(muIn, 64).
    Let mutable rpIn be a new Seq of Int.
    Repeat for x in kk:
        Push x to rpIn.
    Repeat for z from 1 to 32:
        Push 0 to rpIn.
    Repeat for x in mu:
        Push x to rpIn.
    Let rhoPp be shake256(rpIn, 64).
    Let mutable kappa be 0.
    Let mutable done be 0.
    Let mutable sigOut be a new Seq of Int.
    While done is equal to 0:
        Let mutable yFlat be a new Seq of Int.
        Let mutable yHatFlat be a new Seq of Word32.
        Repeat for j from 0 to 4:
            Let mutable ms be a new Seq of Int.
            Repeat for x in rhoPp:
                Push x to ms.
            Push ((kappa + j) % 256) to ms.
            Push ((kappa + j) / 256) to ms.
            Let yj be mldsaUnpackZ(shake256(ms, 640)).
            Repeat for x in yj:
                Push x to yFlat.
            Repeat for x in mldsaNtt(mldsaIntsToW32(yj)):
                Push x to yHatFlat.
        Let mutable wFlat be a new Seq of Word32.
        Let mutable ctIn be a new Seq of Int.
        Repeat for x in mu:
            Push x to ctIn.
        Repeat for i from 0 to 5:
            Let mutable acc be a new Seq of Word32.
            Repeat for kc from 1 to 256:
                Push word32(0) to acc.
            Repeat for j from 0 to 4:
                Let mutable seedA be a new Seq of Int.
                Repeat for x in rho:
                    Push x to seedA.
                Push j to seedA.
                Push i to seedA.
                Set acc to mldsaPolyAdd(acc, pointwiseMontgomery(mldsaIntsToW32(mldsaExpandAElem(seedA)), mldsaSubRangeW(yHatFlat, 256 * j, 256))).
            Let wi be mldsaInvNttToMont(acc).
            Repeat for x in wi:
                Push x to wFlat.
            Let mutable w1i be a new Seq of Int.
            Repeat for c from 1 to 256:
                Push mldsaHighBits(mldsaToS32(item c of wi)) to w1i.
            Repeat for x in mldsaW1Encode(w1i):
                Push x to ctIn.
        Let cTilde be shake256(ctIn, 48).
        Let cHat be mldsaNtt(mldsaIntsToW32(mldsaSampleInBall(cTilde))).
        Let mutable zFlat be a new Seq of Int.
        Let mutable okZ be 1.
        Repeat for j from 0 to 4:
            Let cs1j be mldsaInvNttToMont(pointwiseMontgomery(cHat, mldsaSubRangeW(s1HatFlat, 256 * j, 256))).
            Repeat for c from 0 to 255:
                Let zc be mldsaCenterI((item (256 * j + c + 1) of yFlat) + mldsaToS32(item (c + 1) of cs1j)).
                Let mutable az be zc.
                If az is less than 0:
                    Set az to 0 - az.
                If az is at least 524092:
                    Set okZ to 0.
                Push zc to zFlat.
        Repeat for i from 0 to 5:
            Let cs2i be mldsaInvNttToMont(pointwiseMontgomery(cHat, mldsaSubRangeW(s2HatFlat, 256 * i, 256))).
            Repeat for c from 0 to 255:
                Let r0c be mldsaLowBits((mldsaToS32(item (256 * i + c + 1) of wFlat)) - (mldsaToS32(item (c + 1) of cs2i))).
                Let mutable ar be r0c.
                If ar is less than 0:
                    Set ar to 0 - ar.
                If ar is at least 261692:
                    Set okZ to 0.
        If okZ is equal to 0:
            Set kappa to kappa + 5.
        If okZ is greater than 0:
            Let mutable hFlat be a new Seq of Int.
            Repeat for z from 1 to 1536:
                Push 0 to hFlat.
            Let mutable weight be 0.
            Let mutable okH be 1.
            Repeat for i from 0 to 5:
                Let ct0i be mldsaInvNttToMont(pointwiseMontgomery(cHat, mldsaSubRangeW(t0HatFlat, 256 * i, 256))).
                Let cs2i be mldsaInvNttToMont(pointwiseMontgomery(cHat, mldsaSubRangeW(s2HatFlat, 256 * i, 256))).
                Repeat for c from 0 to 255:
                    Let ct0c be mldsaToS32(item (c + 1) of ct0i).
                    Let rArg be (mldsaToS32(item (256 * i + c + 1) of wFlat)) - (mldsaToS32(item (c + 1) of cs2i)) + ct0c.
                    Let bit be mldsaMakeHint(0 - ct0c, rArg).
                    Set item (256 * i + c + 1) of hFlat to bit.
                    Set weight to weight + bit.
                    Let mutable ac be mldsaCenterI(ct0c).
                    If ac is less than 0:
                        Set ac to 0 - ac.
                    If ac is at least 261888:
                        Set okH to 0.
            If weight is greater than 55:
                Set okH to 0.
            If okH is equal to 0:
                Set kappa to kappa + 5.
            If okH is greater than 0:
                Repeat for x in cTilde:
                    Push x to sigOut.
                Repeat for j from 0 to 4:
                    Repeat for x in mldsaPackZ(mldsaSubRange(zFlat, 256 * j, 256)):
                        Push x to sigOut.
                Repeat for x in mldsaPackHint(hFlat):
                    Push x to sigOut.
                Set done to 1.
    Return sigOut.

## ML-DSA keygen — the full Logos public key: pk = ρ ‖ pack_t1(Power2Round(A·s1 + s2).hi).

## Note
ML-DSA-65 key generation written in LOGOS from a 32-byte seed.

## To mldsaKeygenLogos (seed: Seq of Int) -> Seq of Int:
    Let mutable hIn be a new Seq of Int.
    Repeat for x in seed:
        Push x to hIn.
    Push 6 to hIn.
    Push 5 to hIn.
    Let hash be shake256(hIn, 128).
    Let rho be mldsaSubRange(hash, 0, 32).
    Let rhoPrime be mldsaSubRange(hash, 32, 64).
    Let mutable s1HatFlat be a new Seq of Word32.
    Repeat for j from 0 to 4:
        Let mutable sd be a new Seq of Int.
        Repeat for x in rhoPrime:
            Push x to sd.
        Push (j % 256) to sd.
        Push (j / 256) to sd.
        Let s1j be mldsaExpandSElem(sd).
        Repeat for x in mldsaNtt(mldsaIntsToW32(s1j)):
            Push x to s1HatFlat.
    Let mutable pk be a new Seq of Int.
    Repeat for x in rho:
        Push x to pk.
    Repeat for i from 0 to 5:
        Let mutable acc be a new Seq of Word32.
        Repeat for kc from 1 to 256:
            Push word32(0) to acc.
        Repeat for j from 0 to 4:
            Let mutable seedA be a new Seq of Int.
            Repeat for x in rho:
                Push x to seedA.
            Push j to seedA.
            Push i to seedA.
            Let aHatIJ be mldsaExpandAElem(seedA).
            Set acc to mldsaPolyAdd(acc, pointwiseMontgomery(mldsaIntsToW32(aHatIJ), mldsaSubRangeW(s1HatFlat, 256 * j, 256))).
        Let ti be mldsaInvNttToMont(acc).
        Let mutable sd2 be a new Seq of Int.
        Repeat for x in rhoPrime:
            Push x to sd2.
        Push ((5 + i) % 256) to sd2.
        Push ((5 + i) / 256) to sd2.
        Let s2i be mldsaExpandSElem(sd2).
        Let mutable t1 be a new Seq of Int.
        Repeat for c from 0 to 255:
            Let tc be (mldsaToS32(item (c + 1) of ti)) + (item (c + 1) of s2i).
            Push mldsaPower2RoundT1(tc) to t1.
        Repeat for x in mldsaPackT1(t1):
            Push x to pk.
    Return pk.

## ML-DSA keypair — sk packing (pack_eta / pack_t0 / power2round-low) + the full pk‖sk keypair.

## Note
The low half of Power2Round: t0 from t (FIPS 204).

## To mldsaPower2RoundT0 (t: Int) -> Int:
    Let r be mldsaFreezeI(t).
    Let r1 be (r + 4095) / 8192.
    Return r - r1 * 8192.

## Note
Packs eta-range secret coefficients into key bytes.

## To mldsaPackEta (p: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 127:
        Let lo be 4 - (item (2 * i + 1) of p).
        Let hi be 4 - (item (2 * i + 2) of p).
        Push (lo + hi * 16) to r.
    Return r.

## Note
Packs 13-bit t0 coefficients into secret-key bytes.

## To mldsaPackT0 (p: Seq of Int) -> Seq of Int:
    Let mutable r be a new Seq of Int.
    Repeat for i from 0 to 31:
        Let t0 be 4096 - (item (8 * i + 1) of p).
        Let t1 be 4096 - (item (8 * i + 2) of p).
        Let t2 be 4096 - (item (8 * i + 3) of p).
        Let t3 be 4096 - (item (8 * i + 4) of p).
        Let t4 be 4096 - (item (8 * i + 5) of p).
        Let t5 be 4096 - (item (8 * i + 6) of p).
        Let t6 be 4096 - (item (8 * i + 7) of p).
        Let t7 be 4096 - (item (8 * i + 8) of p).
        Push (t0 % 256) to r.
        Push ((t0 / 256 + t1 * 32) % 256) to r.
        Push ((t1 / 8) % 256) to r.
        Push ((t1 / 2048 + t2 * 4) % 256) to r.
        Push ((t2 / 64 + t3 * 128) % 256) to r.
        Push ((t3 / 2) % 256) to r.
        Push ((t3 / 512 + t4 * 16) % 256) to r.
        Push ((t4 / 16) % 256) to r.
        Push ((t4 / 4096 + t5 * 2) % 256) to r.
        Push ((t5 / 128 + t6 * 64) % 256) to r.
        Push ((t6 / 4) % 256) to r.
        Push ((t6 / 1024 + t7 * 8) % 256) to r.
        Push ((t7 / 32) % 256) to r.
    Return r.

## Note
ML-DSA-65 keypair written in LOGOS: public and secret key bytes.

## To mldsaKeypairLogos (seed: Seq of Int) -> Seq of Int:
    Let mutable hIn be a new Seq of Int.
    Repeat for x in seed:
        Push x to hIn.
    Push 6 to hIn.
    Push 5 to hIn.
    Let hash be shake256(hIn, 128).
    Let rho be mldsaSubRange(hash, 0, 32).
    Let rhoPrime be mldsaSubRange(hash, 32, 64).
    Let kk be mldsaSubRange(hash, 96, 32).
    Let mutable s1Flat be a new Seq of Int.
    Let mutable s1HatFlat be a new Seq of Word32.
    Repeat for j from 0 to 4:
        Let mutable sd be a new Seq of Int.
        Repeat for x in rhoPrime:
            Push x to sd.
        Push (j % 256) to sd.
        Push (j / 256) to sd.
        Let s1j be mldsaExpandSElem(sd).
        Repeat for x in s1j:
            Push x to s1Flat.
        Repeat for x in mldsaNtt(mldsaIntsToW32(s1j)):
            Push x to s1HatFlat.
    Let mutable s2Flat be a new Seq of Int.
    Repeat for i from 0 to 5:
        Let mutable sd2 be a new Seq of Int.
        Repeat for x in rhoPrime:
            Push x to sd2.
        Push ((5 + i) % 256) to sd2.
        Push ((5 + i) / 256) to sd2.
        Let s2i be mldsaExpandSElem(sd2).
        Repeat for x in s2i:
            Push x to s2Flat.
    Let mutable pk be a new Seq of Int.
    Repeat for x in rho:
        Push x to pk.
    Let mutable t0Flat be a new Seq of Int.
    Repeat for i from 0 to 5:
        Let mutable acc be a new Seq of Word32.
        Repeat for kc from 1 to 256:
            Push word32(0) to acc.
        Repeat for j from 0 to 4:
            Let mutable seedA be a new Seq of Int.
            Repeat for x in rho:
                Push x to seedA.
            Push j to seedA.
            Push i to seedA.
            Set acc to mldsaPolyAdd(acc, pointwiseMontgomery(mldsaIntsToW32(mldsaExpandAElem(seedA)), mldsaSubRangeW(s1HatFlat, 256 * j, 256))).
        Let ti be mldsaInvNttToMont(acc).
        Let mutable t1 be a new Seq of Int.
        Repeat for c from 0 to 255:
            Let tc be (mldsaToS32(item (c + 1) of ti)) + (item (256 * i + c + 1) of s2Flat).
            Push mldsaPower2RoundT1(tc) to t1.
            Push mldsaPower2RoundT0(tc) to t0Flat.
        Repeat for x in mldsaPackT1(t1):
            Push x to pk.
    Let tr be shake256(pk, 64).
    Let mutable out be a new Seq of Int.
    Repeat for x in pk:
        Push x to out.
    Repeat for x in rho:
        Push x to out.
    Repeat for x in kk:
        Push x to out.
    Repeat for x in tr:
        Push x to out.
    Repeat for j from 0 to 4:
        Repeat for x in mldsaPackEta(mldsaSubRange(s1Flat, 256 * j, 256)):
            Push x to out.
    Repeat for i from 0 to 5:
        Repeat for x in mldsaPackEta(mldsaSubRange(s2Flat, 256 * i, 256)):
            Push x to out.
    Repeat for i from 0 to 5:
        Repeat for x in mldsaPackT0(mldsaSubRange(t0Flat, 256 * i, 256)):
            Push x to out.
    Return out.
