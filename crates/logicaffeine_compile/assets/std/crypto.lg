## To native sampleNtt (stream: Seq of Int) -> Seq of Int

## Note
Rejection-samples matrix entry A[i][j] from the public seed.

## To native sampleA (seed: Seq of Int) and (i: Int) and (j: Int) -> Seq of Int

## Note
Converts coefficients into the Montgomery domain.

## To native toMont (coeffs: Seq of Int) -> Seq of Int

## Note
SHA3-256 of a byte sequence (FIPS 202).

## To native sha3_256 (a: Seq of Int) -> Seq of Int

## Note
SHA3-512 of a byte sequence (FIPS 202).

## To native sha3_512 (a: Seq of Int) -> Seq of Int

## Note
SHAKE128 extendable output of the requested length (FIPS 202).

## To native shake128 (a: Seq of Int) and (outlen: Int) -> Seq of Int

## Note
SHAKE256 extendable output of the requested length (FIPS 202).

## To native shake256 (a: Seq of Int) and (outlen: Int) -> Seq of Int

## Note
Native ML-KEM-768 key generation from seeds d and z (FIPS 203).

## To native mlkemKeypair (d: Seq of Int) and (z: Seq of Int) -> Seq of Int

## Note
Native ML-KEM-768 encapsulation: ciphertext plus shared secret.

## To native mlkemEncapsKem (ek: Seq of Int) and (m: Seq of Int) -> Seq of Int

## Note
Native ML-KEM-768 decapsulation: the shared secret from a ciphertext.

## To native mlkemDecapsKem (dk: Seq of Int) and (ct: Seq of Int) -> Seq of Int

## Note
Native ML-DSA-65 key generation from a seed (FIPS 204).

## To native mldsaKeypair (seed: Seq of Int) -> Seq of Int

## Note
Native ML-DSA-65 signing with a context string (FIPS 204).

## To native mldsaSign (sk: Seq of Int) and (msg: Seq of Int) and (ctx: Seq of Int) -> Seq of Int

## Note
Native ML-DSA-65 verification; 1 for a valid signature, else 0.

## To native mldsaVerify (pk: Seq of Int) and (msg: Seq of Int) and (ctx: Seq of Int) and (sig: Seq of Int) -> Int

## Note
Copies a length-len slice of a sequence starting at an offset.

## To mlkemSubseq (s: Seq of Int) and (off: Int) and (len: Int) -> Seq of Int:
    Let r be a new Seq of Int.
    Repeat for i from 1 to len:
        Push (item (off + i) of s) to r.
    Return r.

## Note
Copies a length-len Word16 slice starting at an offset.

## To mlkemSubseqW16 (s: Seq of Word16) and (off: Int) and (len: Int) -> Seq of Word16:
    Let r be a new Seq of Word16.
    Repeat for i from 1 to len:
        Push (item (off + i) of s) to r.
    Return r.

## Note
A PRF noise polynomial: SHAKE256(seed, nonce) fed through CBD.

## To mlkemPrfNoise (seed: Seq of Int) and (nonce: Int) -> Seq of Word16:
    Let inp be a new Seq of Int.
    Repeat for x in seed:
        Push x to inp.
    Push nonce to inp.
    Return cbd2W16(shake256(inp, 128)).

## Note
ML-KEM-768 key generation written in LOGOS (FIPS 203).

## To mlkem768Keygen (d: Seq of Int) -> Seq of Int:
    Let gin be a new Seq of Int.
    Repeat for x in d:
        Push x to gin.
    Push 3 to gin.
    Let g be sha3_512(gin).
    Let rho be mlkemSubseq(g, 0, 32).
    Let sigma be mlkemSubseq(g, 32, 32).
    Let seNoise be mlkemNoiseBatch(sigma, 0, 6).
    Let mutable shat be a new Seq of Word16.
    Repeat for j from 0 to 2:
        Set shat to shat followed by mlkemNttW16(mlkemSubseqW16(seNoise, j * 256, 256)).
    Let mutable ehat be a new Seq of Word16.
    Repeat for j from 0 to 2:
        Set ehat to ehat followed by mlkemNttW16(mlkemSubseqW16(seNoise, (3 + j) * 256, 256)).
    Let amatrix be sampleMatrixW16(rho).
    Let mutable ek be a new Seq of Int.
    Repeat for i from 0 to 2:
        Let mutable acc be zerosW16(256).
        Repeat for j from 0 to 2:
            Let aij be mlkemSubseqW16(amatrix, (j * 3 + i) * 256, 256).
            Let sj be mlkemSubseqW16(shat, j * 256, 256).
            Set acc to addModQW16(acc, mlkemBaseMulW16(aij, sj)).
        Let ti be addModQW16(toMontW16(acc), mlkemSubseqW16(ehat, i * 256, 256)).
        Set ek to ek followed by byteEncodeW16(ti, 12).
    Return ek followed by rho.

## Note
K-PKE encryption of a 32-byte message under an encapsulation key.

## To mlkemEncrypt (ek: Seq of Int) and (m: Seq of Int) and (r: Seq of Int) -> Seq of Int:
    Let rho be mlkemSubseq(ek, 1152, 32).
    Let rNoise be mlkemNoiseBatch(r, 0, 7).
    Let mutable rhat be a new Seq of Word16.
    Repeat for j from 0 to 2:
        Set rhat to rhat followed by mlkemNttW16(mlkemSubseqW16(rNoise, j * 256, 256)).
    Let amatrix be sampleMatrixW16(rho).
    Let mutable c be a new Seq of Int.
    Repeat for i from 0 to 2:
        Let mutable acc be zerosW16(256).
        Repeat for j from 0 to 2:
            Let aij be mlkemSubseqW16(amatrix, (i * 3 + j) * 256, 256).
            Let rj be mlkemSubseqW16(rhat, j * 256, 256).
            Set acc to addModQW16(acc, mlkemBaseMulW16(aij, rj)).
        Let ui be addModQW16(mlkemInvNttW16(acc), mlkemSubseqW16(rNoise, (3 + i) * 256, 256)).
        Set c to c followed by byteEncodeW16(compressW16(ui, 10), 10).
    Let mutable accv be zerosW16(256).
    Repeat for i from 0 to 2:
        Let ti be byteDecodeW16(mlkemSubseq(ek, i * 384, 384), 12)
        Let ri be mlkemSubseqW16(rhat, i * 256, 256)
        Set accv to addModQW16(accv, mlkemBaseMulW16(ti, ri))
    Let mu be decompressW16(byteDecodeW16(m, 1), 1).
    Let v be addModQW16(addModQW16(mlkemInvNttW16(accv), mlkemSubseqW16(rNoise, 6 * 256, 256)), mu).
    Return c followed by byteEncodeW16(compressW16(v, 4), 4).

## Note
ML-KEM-768 encapsulation written in LOGOS: ciphertext and shared secret.

## To mlkem768Encaps (ek: Seq of Int) and (m: Seq of Int) -> Seq of Int:
    Let g be sha3_512(m followed by sha3_256(ek)).
    Let kk be mlkemSubseq(g, 0, 32).
    Let r be mlkemSubseq(g, 32, 32).
    Return mlkemEncrypt(ek, m, r) followed by kk.

## Note
K-PKE decryption of a ciphertext with the secret polynomial vector.

## To mlkemDecrypt (dkpke: Seq of Int) and (c: Seq of Int) -> Seq of Int:
    Let mutable acc be zerosW16(256).
    Repeat for i from 0 to 2:
        Let ui be decompressW16(byteDecodeW16(mlkemSubseq(c, i * 320, 320), 10), 10)
        Let si be byteDecodeW16(mlkemSubseq(dkpke, i * 384, 384), 12)
        Set acc to addModQW16(acc, mlkemBaseMulW16(si, mlkemNttW16(ui)))
    Let v be decompressW16(byteDecodeW16(mlkemSubseq(c, 960, 128), 4), 4).
    Let w be subModQW16(v, mlkemInvNttW16(acc)).
    Return byteEncodeW16(compressW16(w, 1), 1).

## Note
Counts differing bytes between two sequences (constant-shape compare).

## To mlkemDiffCount (a: Seq of Int) and (b: Seq of Int) -> Int:
    Let mutable d be 0.
    Let n be length of a.
    Repeat for i from 1 to n:
        Let delta be (item i of a) - (item i of b).
        If delta * delta is at least 1:
            Set d to d + 1.
    Return d.

## Note
ML-KEM-768 decapsulation written in LOGOS, with implicit rejection.

## To mlkem768Decaps (dk: Seq of Int) and (c: Seq of Int) -> Seq of Int:
    Let dkpke be mlkemSubseq(dk, 0, 1152).
    Let ek be mlkemSubseq(dk, 1152, 1184).
    Let h be mlkemSubseq(dk, 2336, 32).
    Let z be mlkemSubseq(dk, 2368, 32).
    Let mprime be mlkemDecrypt(dkpke, c).
    Let g be sha3_512(mprime followed by h).
    Let mutable result be mlkemSubseq(g, 0, 32).
    Let cprime be mlkemEncrypt(ek, mprime, mlkemSubseq(g, 32, 32)).
    If mlkemDiffCount(c, cprime) is at least 1:
        Set result to shake256(z followed by c, 32).
    Return result.

## Note
A post-quantum authenticated handshake transcript over ML-KEM and ML-DSA.

## To pqAuthHandshake (idiPk: Seq of Int) and (idiSk: Seq of Int) and (idrPk: Seq of Int) and (idrSk: Seq of Int) and (kemD: Seq of Int) and (kemZ: Seq of Int) and (kemM: Seq of Int) and (ctx: Seq of Int) -> Seq of Int:
    Let kp be mlkemKeypair(kemD, kemZ).
    Let ek be mlkemSubseq(kp, 0, 1184).
    Let dk be mlkemSubseq(kp, 1184, 2400).
    Let ti be (idiPk followed by idrPk) followed by ek.
    Let sigi be mldsaSignLogos(idiSk, ti).
    If mldsaVerifyLogos(idiPk, ti, sigi) is at most 0:
        Return a new Seq of Int.
    Let ctss be mlkemEncapsKem(ek, kemM).
    Let ct be mlkemSubseq(ctss, 0, 1088).
    Let ssR be mlkemSubseq(ctss, 1088, 32).
    Let tr be ((idiPk followed by idrPk) followed by ek) followed by ct.
    Let sigr be mldsaSignLogos(idrSk, tr).
    If mldsaVerifyLogos(idrPk, tr, sigr) is at most 0:
        Return a new Seq of Int.
    Let ssI be mlkemDecapsKem(dk, ct).
    Return ssI followed by ssR.

## Note
A zeroed byte sequence of the given length.

## To zerosBytes (n: Int) -> Seq of Int:
    Let r be a new Seq of Int.
    Repeat for i from 1 to n:
        Push 0 to r.
    Return r.

## Note
Zero-pads a sequence up to the next 16-byte boundary.

## To pad16 (s: Seq of Int) -> Seq of Int:
    Let n be length of s.
    Let padLen be (16 - (n % 16)) % 16.
    Return zerosBytes(padLen).

## Note
A 64-bit little-endian length encoding as 8 bytes.

## To le64 (n: Int) -> Seq of Int:
    Let r be a new Seq of Int.
    Let mutable v be n.
    Repeat for i from 1 to 8:
        Push (v % 256) to r.
        Set v to v / 256.
    Return r.

## Note
The AEAD MAC input: padded AAD, padded ciphertext, and both lengths.

## To aeadMacData (aad: Seq of Int) and (ct: Seq of Int) -> Seq of Int:
    Let withAad be aad followed by pad16(aad).
    Let withCt be (withAad followed by ct) followed by pad16(ct).
    Return (withCt followed by le64(length of aad)) followed by le64(length of ct).

## Note
ChaCha20-Poly1305 seal: encrypts and appends the 16-byte tag (RFC 8439).

## To aeadSeal (key: Seq of Int) and (nonce: Seq of Int) and (aad: Seq of Int) and (pt: Seq of Int) -> Seq of Int:
    Let otkFull be chacha20Encrypt(key, nonce, 0, zerosBytes(32)).
    Let otk be mlkemSubseq(otkFull, 0, 32).
    Let ct be chacha20Encrypt(key, nonce, 1, pt).
    Let tag be poly1305Mac(otk, aeadMacData(aad, ct)).
    Return ct followed by tag.

## Note
ChaCha20-Poly1305 open: checks the tag, then decrypts; empty on failure.

## To aeadOpen (key: Seq of Int) and (nonce: Seq of Int) and (aad: Seq of Int) and (sealed: Seq of Int) -> Seq of Int:
    Let total be length of sealed.
    If total is at most 15:
        Return a new Seq of Int.
    Let ctLen be total - 16.
    Let ct be mlkemSubseq(sealed, 0, ctLen).
    Let tag be mlkemSubseq(sealed, ctLen, 16).
    Let otkFull be chacha20Encrypt(key, nonce, 0, zerosBytes(32)).
    Let otk be mlkemSubseq(otkFull, 0, 32).
    Let expected be poly1305Mac(otk, aeadMacData(aad, ct)).
    Let mutable diff be 0.
    Repeat for i from 1 to 16:
        Let d be (item i of tag) - (item i of expected).
        If d * d is at least 1:
            Set diff to 1.
    If diff is at least 1:
        Return a new Seq of Int.
    Return chacha20Encrypt(key, nonce, 1, ct).

## Note
Packs little-endian bytes into Word32 words.

## To bytesToWords (bytes: Seq of Int) -> Seq of Word32:
    Let words be a new Seq of Word32.
    Let nw be (length of bytes) / 4.
    Repeat for w from 0 to nw - 1:
        Let base be w * 4.
        Let b0 be item (base + 1) of bytes.
        Let b1 be item (base + 2) of bytes.
        Let b2 be item (base + 3) of bytes.
        Let b3 be item (base + 4) of bytes.
        Push word32(b0 + b1 * 256 + b2 * 65536 + b3 * 16777216) to words.
    Return words.

## Note
The ChaCha20 quarter-round over 8-lane Word32 vectors.

## To laneQR (state: Seq of Lanes8Word32) and (ai: Int) and (bi: Int) and (ci: Int) and (di: Int) -> Seq of Lanes8Word32:
    Let mutable a be item (ai + 1) of state.
    Let mutable b be item (bi + 1) of state.
    Let mutable c be item (ci + 1) of state.
    Let mutable d be item (di + 1) of state.
    Set a to a + b.
    Set d to rotl(d xor a, 16).
    Set c to c + d.
    Set b to rotl(b xor c, 12).
    Set a to a + b.
    Set d to rotl(d xor a, 8).
    Set c to c + d.
    Set b to rotl(b xor c, 7).
    Set item (ai + 1) of state to a.
    Set item (bi + 1) of state to b.
    Set item (ci + 1) of state to c.
    Set item (di + 1) of state to d.
    Return state.

## Note
Eight ChaCha20 blocks at once over 8-lane vectors.

## To laneChaCha20Block (key: Seq of Word32) and (counterBase: Int) and (nonce: Seq of Word32) -> Seq of Lanes8Word32:
    Let mutable state be a new Seq of Lanes8Word32.
    Push splat8Word32(word32(1634760805)) to state.
    Push splat8Word32(word32(857760878)) to state.
    Push splat8Word32(word32(2036477234)) to state.
    Push splat8Word32(word32(1797285236)) to state.
    Repeat for k in key:
        Push splat8Word32(k) to state.
    Let ctr be a new Seq of Word32.
    Repeat for i from 0 to 7:
        Push word32(counterBase + i) to ctr.
    Push lanes8Word32(ctr) to state.
    Repeat for n in nonce:
        Push splat8Word32(n) to state.
    Let init be a new Seq of Lanes8Word32.
    Repeat for s in state:
        Push s to init.
    Repeat for r from 1 to 10:
        Set state to laneQR(state, 0, 4, 8, 12).
        Set state to laneQR(state, 1, 5, 9, 13).
        Set state to laneQR(state, 2, 6, 10, 14).
        Set state to laneQR(state, 3, 7, 11, 15).
        Set state to laneQR(state, 0, 5, 10, 15).
        Set state to laneQR(state, 1, 6, 11, 12).
        Set state to laneQR(state, 2, 7, 8, 13).
        Set state to laneQR(state, 3, 4, 9, 14).
    Let out be a new Seq of Lanes8Word32.
    Repeat for i from 1 to 16:
        Push (item i of state) + (item i of init) to out.
    Return out.

## Note
Flattens 8-lane ChaCha20 blocks into a keystream word sequence.

## To laneKeystreamWords (key: Seq of Word32) and (counterBase: Int) and (nonce: Seq of Word32) -> Seq of Word32:
    Let block be laneChaCha20Block(key, counterBase, nonce).
    Let out be a new Seq of Word32.
    Repeat for lane from 1 to 8:
        Repeat for j from 1 to 16:
            Push (item lane of seqOfLanes8(item j of block)) to out.
    Return out.

## Note
ChaCha20 stream encryption (RFC 8439); apply it again to decrypt.

## To chacha20Encrypt (key: Seq of Int) and (nonce: Seq of Int) and (counter: Int) and (data: Seq of Int) -> Seq of Int:
    Let keyWords be bytesToWords(key).
    Let nonceWords be bytesToWords(nonce).
    Let n be length of data.
    Let ct be a new Seq of Int.
    Let numBatches be (n + 511) / 512.
    Repeat for batch from 0 to numBatches - 1:
        Let off be batch * 512.
        Let ctr be counter + batch * 8.
        Let ks be laneKeystreamWords(keyWords, ctr, nonceWords).
        Let ksBytes be a new Seq of Int.
        Repeat for w in ks:
            Let v be intOfWord32(w).
            Push (v % 256) to ksBytes.
            Push ((v / 256) % 256) to ksBytes.
            Push ((v / 65536) % 256) to ksBytes.
            Push ((v / 16777216) % 256) to ksBytes.
        Let remaining be n - off.
        Let mutable batchLen be 512.
        If remaining is at most 511:
            Set batchLen to remaining.
        Repeat for i from 1 to batchLen:
            Push ((item (off + i) of data) xor (item i of ksBytes)) to ct.
    Return ct.

## Note
Reads a 32-bit little-endian word from bytes at an offset.

## To leWord (b: Seq of Int) and (off: Int) -> Int:
    Return (item (off + 1) of b) + (item (off + 2) of b) * 256 + (item (off + 3) of b) * 65536 + (item (off + 4) of b) * 16777216.

## Note
Carries Poly1305 limbs back into canonical 26-bit range.

## To polyReduce (d: Seq of Int) -> Seq of Int:
    Let c be (item 1 of d) / 67108864.
    Let h0 be (item 1 of d) % 67108864.
    Let d1b be (item 2 of d) + c.
    Let c1 be d1b / 67108864.
    Let h1 be d1b % 67108864.
    Let d2b be (item 3 of d) + c1.
    Let c2 be d2b / 67108864.
    Let h2 be d2b % 67108864.
    Let d3b be (item 4 of d) + c2.
    Let c3 be d3b / 67108864.
    Let h3 be d3b % 67108864.
    Let d4b be (item 5 of d) + c3.
    Let c4 be d4b / 67108864.
    Let h4 be d4b % 67108864.
    Let h0w be h0 + c4 * 5.
    Let h0f be h0w % 67108864.
    Let cw be h0w / 67108864.
    Let h1b be h1 + cw.
    Let c1b be h1b / 67108864.
    Let h1f be h1b % 67108864.
    Let h2f be h2 + c1b.
    Let r be a new Seq of Int.
    Push h0f to r.
    Push h1f to r.
    Push h2f to r.
    Push h3 to r.
    Push h4 to r.
    Return r.

## Note
Clamps the Poly1305 r key as RFC 8439 requires.

## To polyClamp (key: Seq of Int) -> Seq of Int:
    Let t0c be (leWord(key, 0)) % 268435456.
    Let t1a be (leWord(key, 4)) % 268435456.
    Let t1c be t1a - (t1a % 4).
    Let t2a be (leWord(key, 8)) % 268435456.
    Let t2c be t2a - (t2a % 4).
    Let t3a be (leWord(key, 12)) % 268435456.
    Let t3c be t3a - (t3a % 4).
    Let r be a new Seq of Int.
    Push (t0c % 67108864) to r.
    Push ((t0c / 67108864) + (t1c % 1048576) * 64) to r.
    Push ((t1c / 1048576) + (t2c % 16384) * 4096) to r.
    Push ((t2c / 16384) + (t3c % 256) * 262144) to r.
    Push (t3c / 256) to r.
    Return r.

## Note
Loads one 16-byte block into 26-bit limbs with the high bit set.

## To blockLimbs (seq: Seq of Int) and (off: Int) and (hibit: Int) -> Seq of Int:
    Let m0 be leWord(seq, off).
    Let m1 be leWord(seq, off + 4).
    Let m2 be leWord(seq, off + 8).
    Let m3 be leWord(seq, off + 12).
    Let b be a new Seq of Int.
    Push (m0 % 67108864) to b.
    Push ((m0 / 67108864) + (m1 % 1048576) * 64) to b.
    Push ((m1 / 1048576) + (m2 % 16384) * 4096) to b.
    Push ((m2 / 16384) + (m3 % 256) * 262144) to b.
    Push ((m3 / 256) + hibit * 16777216) to b.
    Return b.

## Note
The final partial block: an appended 1 byte, zero-padded to 16.

## To padBlock (msg: Seq of Int) and (base: Int) and (len: Int) -> Seq of Int:
    Let b be a new Seq of Int.
    Repeat for i from 1 to len:
        Push (item (base + i) of msg) to b.
    Push 1 to b.
    Repeat for i from (len + 2) to 16:
        Push 0 to b.
    Return b.

## Note
Poly1305 limb multiplication modulo 2^130 - 5.

## To polyMul (a: Seq of Int) and (b: Seq of Int) -> Seq of Int:
    Let a0 be item 1 of a.
    Let a1 be item 2 of a.
    Let a2 be item 3 of a.
    Let a3 be item 4 of a.
    Let a4 be item 5 of a.
    Let b0 be item 1 of b.
    Let b1 be item 2 of b.
    Let b2 be item 3 of b.
    Let b3 be item 4 of b.
    Let b4 be item 5 of b.
    Let s1 be b1 * 5.
    Let s2 be b2 * 5.
    Let s3 be b3 * 5.
    Let s4 be b4 * 5.
    Let d be a new Seq of Int.
    Push (a0*b0 + a1*s4 + a2*s3 + a3*s2 + a4*s1) to d.
    Push (a0*b1 + a1*b0 + a2*s4 + a3*s3 + a4*s2) to d.
    Push (a0*b2 + a1*b1 + a2*b0 + a3*s4 + a4*s3) to d.
    Push (a0*b3 + a1*b2 + a2*b1 + a3*b0 + a4*s4) to d.
    Push (a0*b4 + a1*b3 + a2*b2 + a3*b1 + a4*b0) to d.
    Return polyReduce(d).

## Note
Limb-wise addition of two Poly1305 accumulators.

## To polyAdd (a: Seq of Int) and (b: Seq of Int) -> Seq of Int:
    Let r be a new Seq of Int.
    Repeat for i from 1 to 5:
        Push ((item i of a) + (item i of b)) to r.
    Return r.

## Note
Broadcasts one limb of each group into a 4-lane Word64 vector.

## To laneOfLimbs (x: Seq of Int) and (l: Int) -> Lanes4Word64:
    Let s be a new Seq of Int.
    Push (item (l + 1) of x) to s.
    Push (item (l + 6) of x) to s.
    Push (item (l + 11) of x) to s.
    Push (item (l + 16) of x) to s.
    Return lanes4Word64(s).

## Note
Absorbs one block group into the Poly1305 accumulator.

## To poly1305Group (t: Seq of Int) and (r: Seq of Int) -> Seq of Int:
    Let r5 be a new Seq of Int.
    Repeat for x in r:
        Push (x * 5) to r5.
    Let va0 be laneOfLimbs(t, 0).
    Let va1 be laneOfLimbs(t, 1).
    Let va2 be laneOfLimbs(t, 2).
    Let va3 be laneOfLimbs(t, 3).
    Let va4 be laneOfLimbs(t, 4).
    Let vb0 be laneOfLimbs(r, 0).
    Let vb1 be laneOfLimbs(r, 1).
    Let vb2 be laneOfLimbs(r, 2).
    Let vb3 be laneOfLimbs(r, 3).
    Let vb4 be laneOfLimbs(r, 4).
    Let vs0 be laneOfLimbs(r5, 0).
    Let vs1 be laneOfLimbs(r5, 1).
    Let vs2 be laneOfLimbs(r5, 2).
    Let vs3 be laneOfLimbs(r5, 3).
    Let vs4 be laneOfLimbs(r5, 4).
    Let dd be a new Seq of Int.
    Push hsumLanes4(((mul32x32to64(va0, vb0) + mul32x32to64(va1, vs4)) + (mul32x32to64(va2, vs3) + mul32x32to64(va3, vs2))) + mul32x32to64(va4, vs1)) to dd.
    Push hsumLanes4(((mul32x32to64(va0, vb1) + mul32x32to64(va1, vb0)) + (mul32x32to64(va2, vs4) + mul32x32to64(va3, vs3))) + mul32x32to64(va4, vs2)) to dd.
    Push hsumLanes4(((mul32x32to64(va0, vb2) + mul32x32to64(va1, vb1)) + (mul32x32to64(va2, vb0) + mul32x32to64(va3, vs4))) + mul32x32to64(va4, vs3)) to dd.
    Push hsumLanes4(((mul32x32to64(va0, vb3) + mul32x32to64(va1, vb2)) + (mul32x32to64(va2, vb1) + mul32x32to64(va3, vb0))) + mul32x32to64(va4, vs4)) to dd.
    Push hsumLanes4(((mul32x32to64(va0, vb4) + mul32x32to64(va1, vb3)) + (mul32x32to64(va2, vb2) + mul32x32to64(va3, vb1))) + mul32x32to64(va4, vb0)) to dd.
    Return polyReduce(dd).

## Note
Poly1305 finalization: full carry, conditional subtract, add s.

## To polyFinalize (h: Seq of Int) and (key: Seq of Int) -> Seq of Int:
    Let h0 be item 1 of h.
    Let h2 be item 3 of h.
    Let h3 be item 4 of h.
    Let h4 be item 5 of h.
    Let c1 be (item 2 of h) / 67108864.
    Let h1n be (item 2 of h) % 67108864.
    Let h2a be h2 + c1.
    Let c2 be h2a / 67108864.
    Let h2n be h2a % 67108864.
    Let h3a be h3 + c2.
    Let c3 be h3a / 67108864.
    Let h3n be h3a % 67108864.
    Let h4a be h4 + c3.
    Let c4 be h4a / 67108864.
    Let h4n be h4a % 67108864.
    Let h0a be h0 + c4 * 5.
    Let c0 be h0a / 67108864.
    Let h0n be h0a % 67108864.
    Let h1b be h1n + c0.
    Let c1c be h1b / 67108864.
    Let h1m be h1b % 67108864.
    Let h2m be h2n + c1c.
    Let g0 be h0n + 5.
    Let cg0 be g0 / 67108864.
    Let g0n be g0 % 67108864.
    Let g1 be h1m + cg0.
    Let cg1 be g1 / 67108864.
    Let g1n be g1 % 67108864.
    Let g2 be h2m + cg1.
    Let cg2 be g2 / 67108864.
    Let g2n be g2 % 67108864.
    Let g3 be h3n + cg2.
    Let cg3 be g3 / 67108864.
    Let g3n be g3 % 67108864.
    Let g4 be h4n + cg3.
    Let mutable f0 be h0n.
    Let mutable f1 be h1m.
    Let mutable f2 be h2m.
    Let mutable f3 be h3n.
    Let mutable f4 be h4n.
    If g4 is at least 67108864:
        Set f0 to g0n.
        Set f1 to g1n.
        Set f2 to g2n.
        Set f3 to g3n.
        Set f4 to (g4 - 67108864).
    Let w0 be f0 + (f1 % 64) * 67108864.
    Let w1 be (f1 / 64) + (f2 % 4096) * 1048576.
    Let w2 be (f2 / 4096) + (f3 % 262144) * 16384.
    Let w3 be (f3 / 262144) + (f4 % 16777216) * 256.
    Let acc0 be w0 + leWord(key, 16).
    Let v0 be acc0 % 4294967296.
    Let acc1 be w1 + leWord(key, 20) + (acc0 / 4294967296).
    Let v1 be acc1 % 4294967296.
    Let acc2 be w2 + leWord(key, 24) + (acc1 / 4294967296).
    Let v2 be acc2 % 4294967296.
    Let acc3 be w3 + leWord(key, 28) + (acc2 / 4294967296).
    Let v3 be acc3 % 4294967296.
    Let tag be a new Seq of Int.
    Push (v0 % 256) to tag.
    Push ((v0 / 256) % 256) to tag.
    Push ((v0 / 65536) % 256) to tag.
    Push ((v0 / 16777216) % 256) to tag.
    Push (v1 % 256) to tag.
    Push ((v1 / 256) % 256) to tag.
    Push ((v1 / 65536) % 256) to tag.
    Push ((v1 / 16777216) % 256) to tag.
    Push (v2 % 256) to tag.
    Push ((v2 / 256) % 256) to tag.
    Push ((v2 / 65536) % 256) to tag.
    Push ((v2 / 16777216) % 256) to tag.
    Push (v3 % 256) to tag.
    Push ((v3 / 256) % 256) to tag.
    Push ((v3 / 65536) % 256) to tag.
    Push ((v3 / 16777216) % 256) to tag.
    Return tag.

## Note
The Poly1305 one-time MAC of a message (RFC 8439).

## To poly1305Mac (key: Seq of Int) and (msg: Seq of Int) -> Seq of Int:
    Let r1 be polyClamp(key).
    Let r2 be polyMul(r1, r1).
    Let r3 be polyMul(r2, r1).
    Let r4 be polyMul(r2, r2).
    Let mult be a new Seq of Int.
    Repeat for x in r4:
        Push x to mult.
    Repeat for x in r3:
        Push x to mult.
    Repeat for x in r2:
        Push x to mult.
    Repeat for x in r1:
        Push x to mult.
    Let n be length of msg.
    Let numGroups be n / 64.
    Let mutable h be a new Seq of Int.
    Repeat for i from 1 to 5:
        Push 0 to h.
    Repeat for g from 0 to numGroups - 1:
        Let base be g * 64.
        Let m0 be blockLimbs(msg, base, 1).
        Let m1 be blockLimbs(msg, base + 16, 1).
        Let m2 be blockLimbs(msg, base + 32, 1).
        Let m3 be blockLimbs(msg, base + 48, 1).
        Let t0 be polyAdd(h, m0).
        Let t be a new Seq of Int.
        Repeat for x in t0:
            Push x to t.
        Repeat for x in m1:
            Push x to t.
        Repeat for x in m2:
            Push x to t.
        Repeat for x in m3:
            Push x to t.
        Set h to poly1305Group(t, mult).
    Let mutable i be numGroups * 64.
    While (i + 16) is at most n:
        Let hm be polyAdd(h, blockLimbs(msg, i, 1)).
        Set h to polyMul(hm, r1).
        Set i to i + 16.
    If i is at most (n - 1):
        Let lenp be n - i.
        Let hp be polyAdd(h, blockLimbs(padBlock(msg, i, lenp), 0, 0)).
        Set h to polyMul(hp, r1).
    Return polyFinalize(h, key).


## ML-DSA (Dilithium) NTT primitives — i32 lanes (Lanes8Word32 / vpmuldq), q = 8380417.

## Note
Copies 8 lanes out of a Word32 sequence starting at an offset.

## To sub8 (s: Seq of Word32) and (off: Int) -> Seq of Word32:
    Let r be a new Seq of Word32.
    Repeat for i from 1 to 8:
        Push (item (off + i) of s) to r.
    Return r.

## Note
One butterfly level of the ML-DSA forward NTT.

## To mldsaWithinLevel (coeffs: Seq of Word32) and (zetas: Seq of Word32) and (h: Int) and (k0: Int) -> Seq of Word32:
    Let qv be splat8Word32(word32(8380417)).
    Let qiv be splat8Word32(word32(58728449)).
    Let mutable r be a new Seq of Word32.
    Repeat for x in coeffs:
        Push x to r.
    Let blocksPerVec be 8 / (2 * h).
    Let lanesPerBlock be 2 * h.
    Repeat for v from 0 to 31:
        Let zvSeq be a new Seq of Word32.
        Repeat for bj from 0 to blocksPerVec - 1:
            Let zeta be item (k0 + v * blocksPerVec + bj + 1) of zetas.
            Repeat for rep from 1 to lanesPerBlock:
                Push zeta to zvSeq.
        Let zv be lanes8Word32(zvSeq).
        Let vec be lanes8Word32(sub8(r, 8 * v)).
        Let lo be nttBcastLo(vec, h).
        Let hiB be nttBcastHi(vec, h).
        Let t be montmul32(zv, hiB, qv, qiv).
        Let rs be seqOfLanes8(nttBlend(lo + t, lo - t, h)).
        Repeat for i from 1 to 8:
            Set item (8 * v + i) of r to (item i of rs).
    Return r.

## Note
The ML-DSA forward NTT, level by level.

## To mldsaNttForward (coeffs: Seq of Word32) and (zetas: Seq of Word32) -> Seq of Word32:
    Let qv be splat8Word32(word32(8380417)).
    Let qiv be splat8Word32(word32(58728449)).
    Let mutable r be a new Seq of Word32.
    Repeat for x in coeffs:
        Push x to r.
    Let mutable k be 1.
    Let mutable len be 128.
    While len is at least 8:
        Let numBlocks be 128 / len.
        Let chunks be len / 8.
        Repeat for b from 0 to numBlocks - 1:
            Let zv be splat8Word32(item k of zetas).
            Let start be b * 2 * len.
            Repeat for c from 0 to chunks - 1:
                Let lowOff be start + 8 * c.
                Let highOff be start + len + 8 * c.
                Let lowVec be lanes8Word32(sub8(r, lowOff)).
                Let highVec be lanes8Word32(sub8(r, highOff)).
                Let t be montmul32(zv, highVec, qv, qiv).
                Let nl be seqOfLanes8(lowVec + t).
                Let nh be seqOfLanes8(lowVec - t).
                Repeat for i from 1 to 8:
                    Set item (lowOff + i) of r to (item i of nl).
                    Set item (highOff + i) of r to (item i of nh).
            Set k to k + 1.
        Set len to len / 2.
    Let mutable k0 be k - 1.
    Set r to mldsaWithinLevel(r, zetas, 4, k0).
    Set k0 to k0 + 32.
    Set r to mldsaWithinLevel(r, zetas, 2, k0).
    Set k0 to k0 + 64.
    Set r to mldsaWithinLevel(r, zetas, 1, k0).
    Return r.

## Note
One butterfly level of the ML-DSA inverse NTT.

## To mldsaInvWithinLevel (coeffs: Seq of Word32) and (zetas: Seq of Word32) and (h: Int) and (kStart: Int) -> Seq of Word32:
    Let qv be splat8Word32(word32(8380417)).
    Let qiv be splat8Word32(word32(58728449)).
    Let mutable r be a new Seq of Word32.
    Repeat for x in coeffs:
        Push x to r.
    Let blocksPerVec be 8 / (2 * h).
    Let lanesPerBlock be 2 * h.
    Repeat for v from 0 to 31:
        Let zvSeq be a new Seq of Word32.
        Repeat for bj from 0 to blocksPerVec - 1:
            Let g be v * blocksPerVec + bj.
            Let zeta be item (kStart - g + 1) of zetas.
            Repeat for rep from 1 to lanesPerBlock:
                Push zeta to zvSeq.
        Let zv be lanes8Word32(zvSeq).
        Let vec be lanes8Word32(sub8(r, 8 * v)).
        Let loB be nttBcastLo(vec, h).
        Let hiB be nttBcastHi(vec, h).
        Let sum be loB + hiB.
        Let newHi be montmul32(zv, hiB - loB, qv, qiv).
        Let rs be seqOfLanes8(nttBlend(sum, newHi, h)).
        Repeat for i from 1 to 8:
            Set item (8 * v + i) of r to (item i of rs).
    Return r.

## Note
The ML-DSA inverse NTT, level by level.

## To mldsaInvNtt (coeffs: Seq of Word32) and (zetas: Seq of Word32) -> Seq of Word32:
    Let qv be splat8Word32(word32(8380417)).
    Let qiv be splat8Word32(word32(58728449)).
    Let mutable r be a new Seq of Word32.
    Repeat for x in coeffs:
        Push x to r.
    Set r to mldsaInvWithinLevel(r, zetas, 1, 255).
    Set r to mldsaInvWithinLevel(r, zetas, 2, 127).
    Set r to mldsaInvWithinLevel(r, zetas, 4, 63).
    Let mutable kStart be 31.
    Let mutable len be 8.
    While len is at most 128:
        Let numBlocks be 128 / len.
        Let chunks be len / 8.
        Repeat for b from 0 to numBlocks - 1:
            Let zv be splat8Word32(item (kStart - b + 1) of zetas).
            Let start be b * 2 * len.
            Repeat for c from 0 to chunks - 1:
                Let lowOff be start + 8 * c.
                Let highOff be start + len + 8 * c.
                Let lowVec be lanes8Word32(sub8(r, lowOff)).
                Let highVec be lanes8Word32(sub8(r, highOff)).
                Let sumv be lowVec + highVec.
                Let newHi be montmul32(zv, highVec - lowVec, qv, qiv).
                Let nl be seqOfLanes8(sumv).
                Let nh be seqOfLanes8(newHi).
                Repeat for i from 1 to 8:
                    Set item (lowOff + i) of r to (item i of nl).
                    Set item (highOff + i) of r to (item i of nh).
        Set kStart to kStart - numBlocks.
        Set len to len * 2.
    Let fv be splat8Word32(word32(41978)).
    Repeat for v from 0 to 31:
        Let vec be lanes8Word32(sub8(r, 8 * v)).
        Let scaled be seqOfLanes8(montmul32(fv, vec, qv, qiv)).
        Repeat for i from 1 to 8:
            Set item (8 * v + i) of r to (item i of scaled).
    Return r.

## Note
Pointwise Montgomery multiply of two NTT-domain polynomials.

## To pointwiseMontgomery (a: Seq of Word32) and (b: Seq of Word32) -> Seq of Word32:
    Let qv be splat8Word32(word32(8380417)).
    Let qiv be splat8Word32(word32(58728449)).
    Let mutable out be a new Seq of Word32.
    Repeat for v from 0 to 31:
        Let av be lanes8Word32(sub8(a, 8 * v)).
        Let bv be lanes8Word32(sub8(b, 8 * v)).
        Repeat for x in seqOfLanes8(montmul32(av, bv, qv, qiv)):
            Push x to out.
    Return out.

## Note
Freezes every coefficient into canonical range mod q.

## To mldsaFreezePoly (c: Seq of Word32) -> Seq of Word32:
    Let mutable out be a new Seq of Word32.
    Repeat for x in c:
        Let raw be intOfWord32(x).
        Let v be raw.
        If v is at least 2147483648:
            Set v to v - 4294967296.
        Push word32(((v % 8380417) + 8380417) % 8380417) to out.
    Return out.

## Note
Forward NTT for ML-DSA polynomials, lane-accelerated.

