{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "markdown.logicaffeine.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [{ "include": "#logicaffeine-code-block" }],
  "repository": {
    "logicaffeine-code-block": {
      "begin": "(^|\\G)([ ]*)(`{3,}|~{3,})\\s*(?i:(logicaffeine|logos|lg))(\\s*[^`~]*)?$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "end": "(^|\\G)(\\2)(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "name": "markup.fenced_code.block.markdown",
      "contentName": "meta.embedded.block.logicaffeine",
      "patterns": [{ "include": "source.logicaffeine" }]
    }
  }
}
